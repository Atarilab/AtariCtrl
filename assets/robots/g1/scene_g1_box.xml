<mujoco model="scene_g1_box">
  <compiler angle="radian" meshdir="meshes"/>
  
  <option iterations="10" ls_iterations="20" timestep="0.005" integrator="implicitfast" solver="Newton" noslip_iterations="0">
    <flag eulerdamp="disable"/>
  </option>

  <include file="g1_29dof_rev_1_0.xml"/>

  
  <worldbody>
    <!-- Dynamic cube -->
    <body name="box" pos="0.3 0.0 0.175" euler="0 0 0">
      <joint name="box_free_joint" type="free" limited="false" actuatorfrclimited="false"/>
      <!-- <geom name="box_geom" type="box" size="0.1 0.1 0.115" mass="0.6" rgba="0.2 0.6 0.8 1" friction="1.0 0.005 0.0001"/> -->
      <geom name="box_geom" type="box" size="0.155 0.155 0.17" mass="0.6" rgba="0.2 0.6 0.8 1" friction="0.6 0.005 0.0001"/>
      <!-- Frame visualization: X (red), Y (green), Z (blue) axes -->
      <geom name="box_frame_x" type="cylinder" size="0.005 0.1" pos="0.1 0 0" euler="0 1.5708 0" rgba="1 0 0 1" contype="0" conaffinity="0"/>
      <geom name="box_frame_y" type="cylinder" size="0.005 0.1" pos="0 0.1 0" euler="1.5708 0 0" rgba="0 1 0 1" contype="0" conaffinity="0"/>
      <geom name="box_frame_z" type="cylinder" size="0.005 0.1" pos="0 0 0.1" euler="0 0 0" rgba="0 0 1 1" contype="0" conaffinity="0"/>


    </body>
  </worldbody>
</mujoco>

